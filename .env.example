# ─── Local Development ───────────────────────────────────────────────

# Database (local PostgreSQL via docker-compose)
DATABASE_URL=postgresql://poker:poker_secret@localhost:5432/poker_tournament

# SMTP (Mailhog via docker-compose — no auth needed)
SMTP_HOST=127.0.0.1
SMTP_PORT=1025

# Seed data (comma-separated emails, used by: pnpm db:seed)
ADMIN_EMAILS=your.name@scelto.no
SEED_USERS=player.one@scelto.no,player.two@scelto.no

# App
APP_URL=http://localhost:5173
JWT_SECRET=dev-jwt-secret-change-in-prod
PORT=3001

# Generate VAPID keys with: pnpm generate-vapid
VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key
VAPID_EMAIL=mailto:admin@scelto.no

# Client (Vite) — API/WS go through Vite proxy, no URL needed
VITE_VAPID_PUBLIC_KEY=your_vapid_public_key

# ─── Production (Render + Neon + Brevo) ──────────────────────────────
# DATABASE_URL=postgresql://...@....neon.tech/poker_tournament?sslmode=require
# BREVO_API_KEY=your_brevo_api_v3_key
# SMTP_FROM="Scelto Poker" <your-verified-sender@example.com>
# APP_URL=https://scelto-poker.onrender.com
# JWT_SECRET=<auto-generated by render.yaml>
